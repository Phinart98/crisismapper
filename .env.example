# CrisisMapper — environment variables
# Copy to .env and fill in values; never commit .env

# Supabase (from project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Supavisor pooler (Settings → Database → Transaction mode, port 6543)
# Append ?prepareThreshold=0 to the connection string
DB_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?prepareThreshold=0

