# CrisisMapper — environment variables
# Copy to .env and fill in values; never commit .env
# Nuxt 4 maps runtimeConfig keys via NUXT_* prefix:
#   runtimeConfig.dbUrl           → NUXT_DB_URL
#   runtimeConfig.supabaseServiceKey → NUXT_SUPABASE_SERVICE_KEY
#   runtimeConfig.public.supabaseUrl → NUXT_PUBLIC_SUPABASE_URL
#   runtimeConfig.public.supabaseAnonKey → NUXT_PUBLIC_SUPABASE_ANON_KEY

# Supavisor pooler (Settings → Database → Connect → Transaction mode, port 6543)
# Append ?prepareThreshold=0 and URL-encode % in password as %25
NUXT_DB_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?prepareThreshold=0

# Supabase (Settings → API)
NUXT_SUPABASE_SERVICE_KEY=
NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 2 — Demo crisis UUID (seeded via supabase/migrations/20260507000000_seed_demo_crisis.sql)
NUXT_PUBLIC_DEMO_CRISIS_ID=

# Phase 4+ — AI classification
# GROQ_API_KEY=
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_VISION_FALLBACK=meta-llama/llama-4-maverick-17b-128e-instruct

# Phase 5+ — WhatsApp Meta Cloud API
# META_WHATSAPP_TOKEN=
# META_WEBHOOK_VERIFY_TOKEN=
# META_APP_SECRET=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ID_HMAC_SECRET=
